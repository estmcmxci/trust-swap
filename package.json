{
  "name": "trust-swap",
  "version": "0.0.0",
  "description": "Trust-gated settlement on Uniswap. Reference implementation of the gate-then-execute pattern over @synthesis/resolver.",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "format": "pnpm -r format",
    "oracle:keygen": "tsx scripts/generate-oracle-keypair.ts",
    "oracle:export-key": "tsx scripts/oracle-export-key.ts",
    "synthesis:export-key": "tsx scripts/synthesis-export-key.ts",
    "kernel:issue": "tsx --env-file=.env scripts/issue-kernel-account.ts",
    "kernel:withdraw": "tsx --env-file=.env scripts/kernel-withdraw.ts",
    "session-key:issue": "tsx --env-file=.env scripts/issue-session-key.ts",
    "smoke:uniswap": "tsx --env-file=.env scripts/smoke-uniswap.ts",
    "smoke:bundler": "tsx --env-file=.env scripts/smoke-bundler.ts",
    "e2e:phase1": "scripts/e2e-phase1.sh"
  },
  "devDependencies": {
    "@namera-ai/sdk": "^0.1.0",
    "@zerodev/multi-chain-ecdsa-validator": "^5.4.5",
    "@zerodev/permissions": "^5.6.3",
    "@zerodev/sdk": "^5.5.8",
    "tsx": "^4.20.6",
    "viem": "^2.33.3"
  },
  "license": "MIT"
}
