{
  "name": "@trust-swap/oracle",
  "version": "0.0.0",
  "description": "TrustSwap Oracle — off-chain HTTP service that re-resolves both sides via TRL, checks RiskPolicies, and signs attestations the on-chain TrustSwapRouter verifies.",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --outDir dist",
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "lint": "biome lint --write .",
    "format": "biome format --write ."
  },
  "dependencies": {
    "@synthesis/resolver": "file:../../vendor/synthesis-resolver",
    "@trust-swap/core": "workspace:*",
    "hono": "^4.6.0",
    "viem": "^2.33.3",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@cloudflare/workers-types": "^4.20240909.0",
    "tsup": "^8.5.1",
    "typescript": "^5.8.3",
    "wrangler": "^4.46.0"
  },
  "license": "MIT"
}
