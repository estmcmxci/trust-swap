{
  "name": "@trust-swap/cli",
  "version": "0.0.0",
  "description": "TrustSwap CLI — `tru swap`, `tru agent run`",
  "type": "module",
  "bin": {
    "tru": "./dist/index.js"
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --outDir dist",
    "dev": "tsx src/index.ts",
    "lint": "biome lint --write .",
    "format": "biome format --write .",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@namera-ai/sdk": "^0.1.0",
    "@synthesis/resolver": "file:../../vendor/synthesis-resolver",
    "@trust-swap/core": "workspace:*",
    "@zerodev/multi-chain-ecdsa-validator": "^5.4.5",
    "@zerodev/permissions": "^5.6.3",
    "@zerodev/sdk": "^5.5.8",
    "dotenv": "^17.3.1",
    "incur": "^0.3.5",
    "viem": "^2.33.3",
    "yoctocolors": "^2.1.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^22.19.15",
    "tsup": "^8.5.1",
    "tsx": "^4.20.6",
    "typescript": "^5.8.3",
    "vitest": "^2.1.9"
  },
  "license": "MIT"
}
