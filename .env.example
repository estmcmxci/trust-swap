# TrustSwap environment — copy to .env and fill in.
# Phase 0: operational readiness. Most values come from external accounts.

# ---------------------------------------------------------------------------
# Uniswap Trading API (Phase 1)
# Register at https://developers.uniswap.org → Create app → copy key
# ---------------------------------------------------------------------------
UNISWAP_API_KEY=

# Trading API base URL. Default v1 endpoint; override only if Uniswap rotates.
UNISWAP_TRADING_API_URL=https://trade-api.gateway.uniswap.org/v1

# ---------------------------------------------------------------------------
# Base mainnet bundler — ERC-4337 (Phase 0/1)
# Pimlico: https://dashboard.pimlico.io  |  Alchemy: https://dashboard.alchemy.com
# Provide at least one; supply both for failover.
# ---------------------------------------------------------------------------
BUNDLER_URL_BASE=
BUNDLER_URL_BASE_FALLBACK=

# Base RPC for read-only viem clients. Public Base RPC works for development.
BASE_RPC_URL=https://mainnet.base.org

# ---------------------------------------------------------------------------
# Namera (session-key signer) — Phase 1
# Owner key issued by `pnpm kernel:issue` → encrypted to NAMERA_KEYSTORE_PATH.
# Session key + signer issued in Phase 1 (one-time ceremony).
# ---------------------------------------------------------------------------
NAMERA_KEYSTORE_PATH=
NAMERA_KEYSTORE_PASSWORD=
NAMERA_KERNEL_ACCOUNT_ADDRESS=
NAMERA_OWNER_ADDRESS=

# Session-key serialized account string (base64). Issued in Phase 1; consumed
# by `createNameraSigner` from @synthesis/resolver.
NAMERA_SESSION_KEY_PATH=
NAMERA_SESSION_KEY_PRIVATE_KEY=

# ---------------------------------------------------------------------------
# TrustSwap Oracle (Phases 0–2)
#
# ORACLE_PRIVATE_KEY: KEEP EMPTY locally. The plaintext key only needs to
#   exist on the deployed CF Worker — set via `wrangler secret put`, never
#   on dev disk. Canonical encrypted source: `~/.trust-swap/oracle.key`
#   (scrypt + aes-256-ctr, generated by `pnpm oracle:keygen`).
#   To deploy/rotate: `pnpm --silent oracle:export-key | (cd packages/oracle && wrangler secret put ORACLE_PRIVATE_KEY)`.
#
# ORACLE_PUBKEY_ADDRESS: public — pinned in the router constructor.
# ORACLE_URL: production oracle worker URL.
# ---------------------------------------------------------------------------
ORACLE_PRIVATE_KEY=
ORACLE_PUBKEY_ADDRESS=

# Oracle service URL — set after Phase 0 placeholder deploy / Phase 2 real deploy.
ORACLE_URL=

# ---------------------------------------------------------------------------
# TrustSwapRouter (Phase 2)
# Filled in after `forge script ... --broadcast` in Phase 2.
# Canonical Base mainnet deploy is recorded at infra/router/deployment.json.
# ---------------------------------------------------------------------------
TRUST_SWAP_ROUTER_ADDRESS=

# Optional — for `forge ... --verify --etherscan-api-key`. Free at basescan.org/myapikey.
BASESCAN_API_KEY=

# ---------------------------------------------------------------------------
# Synthesis resolver — already-shipped TRL substrate
# Keystore path is the synthesis-managed encrypted owner key.
# ---------------------------------------------------------------------------
SYNTHESIS_KEYSTORE_PATH=~/.synthesis/keystore.json
