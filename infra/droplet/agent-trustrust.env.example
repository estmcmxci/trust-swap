# TrustSwap daemon-2 environment — copy to /etc/trust-swap/agent-trustrust.env (mode 0600).
# install.sh --instance trustrust seeds this file when missing; re-running won't clobber edits.

# --- Bundler + RPC --------------------------------------------------------
BUNDLER_URL_BASE=
BASE_RPC_URL=https://mainnet.base.org

# --- TrustSwap router (CREATE2-deterministic; do not edit unless we
# redeploy — see infra/router/deployment.json) ---------------------------
TRUST_SWAP_ROUTER_ADDRESS=0xa18E7eBD3E1B19067Ec3473d44847AfBd553679d

# --- Off-chain services --------------------------------------------------
ORACLE_URL=
UNISWAP_API_KEY=

# --- Status endpoint (Tailscale-bound) -----------------------------------
# Replace with the droplet's Tailscale IPv4. NEVER bind to 0.0.0.0 — the
# JSONL ring buffer would be world-readable. Daemon-2 uses port 18791 so
# both daemons can coexist on one droplet; the agent-endpoint ENS record
# at daemon.trustrust.eth resolves to this URL.
TRU_AGENT_STATUS_BIND=100.121.243.97:18791

# --- Optional ------------------------------------------------------------
# NAMERA_DAEMON_SESSION_KEY_VALID_HOURS=168
